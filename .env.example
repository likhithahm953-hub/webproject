FLASK_SECRET_KEY=replace-with-a-strong-random-secret
DATABASE_URL=sqlite:///instance/database.db
SERVER_BASE_URL=https://your-app.onrender.com

REQUIRE_EMAIL_VERIFICATION=true
EMAIL_PROVIDER=nodemailer

# Nodemailer / SMTP
NODEMAILER_HOST=smtp.gmail.com
NODEMAILER_PORT=587
NODEMAILER_USE_AUTH=true
NODEMAILER_USER=your-email@example.com
NODEMAILER_PASS=your-app-password-or-smtp-password
EMAIL_FROM=noreply@yourdomain.com
NODEMAILER_ALLOW_INSECURE=false

# Optional
RESEND_API_KEY=
GEMINI_API_KEY=